<?xml version="1.0" encoding="utf-8"?>
<!-- Backs the FileProvider used by ExportShare.kt (PRD P1-1/P1-2): only the app's own
     cache/exports subdirectory is exposed, nothing else under cacheDir or filesDir. -->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <cache-path name="exports" path="exports/" />
    <!-- Downloaded update APKs (PRD #22/T22), handed to the system package installer. -->
    <cache-path name="updates" path="updates/" />
    <!-- Raw camera captures for profile photos, handed to the camera app as the
         TakePicture output target; AvatarPhotoStore crops them and deletes the raw file. -->
    <cache-path name="avatar_capture" path="avatar_capture/" />
</paths>
