<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for the Classes content layer (PRD P0-6, T9/T10): fetching per-channel
         YouTube RSS feeds and loading thumbnails via Coil both need network access. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- BLE heart-rate strap pairing/connection (PRD P1-4, T17). Two permission sets, split by
         API level (see core/heartrate/BlePermissions.kt):

         - API <=30 (this project's actual target hardware, the Bike Gen 2 tablet on Android
           11): BLUETOOTH/BLUETOOTH_ADMIN are install-time "normal" permissions here (never
           requested at runtime); ACCESS_FINE_LOCATION is the runtime permission BLE scanning
           needs on these levels. maxSdkVersion="30" keeps them out of the merged manifest on
           API 31+, where they're superseded by the two permissions below.
         - API 31+ (Android 12+): BLUETOOTH_SCAN/BLUETOOTH_CONNECT are the dedicated runtime
           BLE permissions. `neverForLocation` on the scan permission is accurate here — this
           app only scans for the Heart Rate Service UUID, never derives location from scan
           results — and lets a user on 12+ grant it without also granting location. -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Opt-in in-app self-updater (PRD #22, T22): lets OpenRide hand a downloaded APK to the
         system package installer, so updating the bike's tablet doesn't mean re-running ADB.
         This only permits *asking*: the platform installer still shows its own confirmation, and
         the user must additionally allow "install unknown apps" for OpenRide in Settings. Nothing
         is fetched or installed unless a manifest URL has been configured and the user taps
         through — there is no baked-in update endpoint. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:theme="@style/Theme.OpenRide"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.OpenRide">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Backs ExportShare.kt (PRD P1-1/P1-2, T14): hands exported TCX/CSV files to the
             Android share sheet via a content:// URI instead of a raw file:// path. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--
          Opt-in HOME launcher alias for MainActivity (PRD P0-8, T12). Disabled by default
          (android:enabled="false") so simply installing the app never hijacks the tablet's
          home screen — the rider opts in explicitly via:

              adb shell pm enable dev.digitalducktape.openride/.HomeLauncherAlias

          documented in docs/INSTALL.md, which also covers reverting it. Since MainActivity's
          own nav graph always starts at profile-select (see OpenRideNavHost), being launched
          as HOME already lands on profile-select with no separate boot-time logic needed —
          this alias just makes Android *offer* MainActivity as a home-screen replacement.

          A separate <activity-alias>, not a second intent-filter directly on MainActivity,
          so the HOME/DEFAULT categories can be toggled independently of the app's normal
          launcher icon (which stays enabled unconditionally).
        -->
        <activity-alias
            android:name=".HomeLauncherAlias"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:enabled="false"
            android:icon="@android:drawable/sym_def_app_icon"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity-alias>
    </application>

</manifest>
