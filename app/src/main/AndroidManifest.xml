<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for the Classes content layer (PRD P0-6, T9/T10): fetching per-channel
         YouTube RSS feeds and loading thumbnails via Coil both need network access. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:theme="@style/Theme.OpenRide"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.OpenRide">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Opt-in HOME launcher alias for MainActivity (PRD P0-8, T12). Disabled by default
          (android:enabled="false") so simply installing the app never hijacks the tablet's
          home screen — the rider opts in explicitly via:

              adb shell pm enable dev.digitalducktape.openride/.HomeLauncherAlias

          documented in docs/INSTALL.md, which also covers reverting it. Since MainActivity's
          own nav graph always starts at profile-select (see OpenRideNavHost), being launched
          as HOME already lands on profile-select with no separate boot-time logic needed —
          this alias just makes Android *offer* MainActivity as a home-screen replacement.

          A separate <activity-alias>, not a second intent-filter directly on MainActivity,
          so the HOME/DEFAULT categories can be toggled independently of the app's normal
          launcher icon (which stays enabled unconditionally).
        -->
        <activity-alias
            android:name=".HomeLauncherAlias"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:enabled="false"
            android:icon="@android:drawable/sym_def_app_icon"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity-alias>
    </application>

</manifest>
